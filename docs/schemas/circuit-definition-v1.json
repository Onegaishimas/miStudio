        "layer": {
          "minimum": 0,
          "title": "Layer",
          "type": "integer"
        },
        "member_kind": {
          "default": "feature_ref",
          "enum": [
            "feature_ref",
            "cluster_ref"
          ],
          "title": "Member Kind",
          "type": "string"
        }
      },
      "required": [
        "layer"
      ],
      "title": "CircuitMember",
      "type": "object"
    },
