          "default": null,
          "title": "Weight Prior"
        }
      },
      "required": [
        "up",
        "down"
      ],
      "title": "CircuitEdge",
      "type": "object"
    },
    "CircuitFaithfulness": {
      "description": "Circuit-level faithfulness snapshot (CIRCUITS-002 A.7); badge, not gate.",
