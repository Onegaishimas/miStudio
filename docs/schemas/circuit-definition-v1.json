{
  "$defs": {
    "CircuitBudget": {
      "description": "Per-layer budgets composed under one global intensity (IDL-31).",
      "properties": {
        "formula_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "freq-budget/sim-alloc/per-layer@1",
          "title": "Formula Id"
        },
        "intensity": {
          "default": 1.0,
          "maximum": 2.0,
          "minimum": 0.0,
          "title": "Intensity",
          "type": "number"
        },
        "intensity_range": {
          "items": {
            "type": "number"
          },
          "title": "Intensity Range",
          "type": "array"
        },
        "layers": {
          "additionalProperties": {
            "$ref": "#/$defs/ProfileBudget"
          },
          "title": "Layers",
          "type": "object"
        }
      },
      "title": "CircuitBudget",
      "type": "object"
    },
    "CircuitDefinitionV1": {
      "description": "One portable circuit definition (IDL-33).",
      "properties": {
        "budget": {
          "anyOf": [
            {
              "$ref": "#/$defs/CircuitBudget"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "discovery": {
          "anyOf": [
            {
              "$ref": "#/$defs/CircuitDiscoveryProvenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "edges": {
          "items": {
            "$ref": "#/$defs/CircuitEdge"
          },
          "maxItems": 200,
          "title": "Edges",
          "type": "array"
        },
        "faithfulness": {
          "anyOf": [
            {
              "$ref": "#/$defs/CircuitFaithfulness"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "const": "mistudio.circuit-definition",
          "default": "mistudio.circuit-definition",
          "title": "Kind",
          "type": "string"
        },
        "members": {
          "items": {
            "$ref": "#/$defs/CircuitMember"
          },
          "minItems": 1,
          "title": "Members",
          "type": "array"
        },
        "model": {
          "$ref": "#/$defs/DefinitionModelRef"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "narrative": {
          "anyOf": [
            {
              "maxLength": 10000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Narrative"
        },
        "provenance": {
          "$ref": "#/$defs/DefinitionProvenance"
        },
        "saes": {
          "items": {
            "$ref": "#/$defs/DefinitionSAERef"
          },
          "maxItems": 16,
          "minItems": 1,
          "title": "Saes",
          "type": "array"
        },
        "schema_version": {
          "const": "1",
          "default": "1",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "saes",
        "members"
      ],
      "title": "CircuitDefinitionV1",
      "type": "object"
    },
