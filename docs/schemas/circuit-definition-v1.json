        "type_signals": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Type Signals"
        },
        "up": {
          "$ref": "#/$defs/CircuitNodeRef"
        },
        "validation_manifest_ref": {
          "anyOf": [
            {
              "type": "string"
