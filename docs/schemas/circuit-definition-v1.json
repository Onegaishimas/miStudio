    "CircuitMember": {
      "description": "A circuit member at a layer \u2014 a feature ref or a cluster (supernode) ref.\n\nCluster members carry an expansion snapshot so exports stay portable even\nif the referenced profile later changes (live records resolve dynamically;\nthe definition freezes the membership at export time).",
      "properties": {
        "cluster_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cluster Name"
        },
        "cluster_profile_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cluster Profile Id"
        },
        "expanded_members": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ProfileMember"
              },
              "maxItems": 20,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expanded Members"
        },
        "feature": {
          "anyOf": [
